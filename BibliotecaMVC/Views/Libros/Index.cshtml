@using BibliotecaMVC.Models

@{
    List<Libro> libros = ViewBag.Libros;
}

<h1>@ViewBag.Nombre</h1>
<h2>Catálogo de Libros</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Autor</th>
            <th>Categoría</th>
            <th>Precio</th>
            <th>Disponibilidad</th>
        </tr>
    </thead>
    <tbody>
    @foreach
    (var libro in libros)
    {
        <tr>
            <td>@libro.ID</td>
            <td>@libro.Titulo</td>
            <td>@libro.Autor</td>
            <td>@libro.Categoria</td>
            <td>@libro.Precio</td>
            <td>
                @if (libro.Disponible)
                {
                    <span class="badge bg-success">Disponible</span>
                }
                else
                {
                    <span class="badge bg-danger">Prestado</span>
                }
            </td>
        </tr>
    }
    </tbody>
</table>